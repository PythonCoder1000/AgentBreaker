# Copy this file to `.env` and fill in your key.
#   cp .env.template .env
# Get a key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Optional HTTP Basic Auth for the web demo. Set BOTH to require a username +
# password before anyone can reach the app (recommended for any public deploy —
# it protects your API credits and the Prompt Agent's shell tools). Leave both
# blank to run the demo open (fine for local dev).
BASIC_AUTH_USER=
BASIC_AUTH_PASS=

# Optional: real credentials the access layer (src/broker.py) leases at runtime
# for call_api. Leave these UNSET to let the broker mint synthetic, per-process
# secrets so the demo runs with zero external setup. To broker REAL secrets,
# inject them here at runtime from your secrets manager — so the secret is issued
# at runtime, scoped to the task, and never written into the repo or the model's
# context. The names match settings.BROKER_SECRET_ENV.
PAYMENTS_API_KEY=
DEPLOY_TOKEN=
HELIOS_API_KEY=
