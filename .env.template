# Copy this file to `.env` and fill in your key.
#   cp .env.template .env
# Get a key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Optional HTTP Basic Auth for the web demo. Set BOTH to require a username +
# password before anyone can reach the app (recommended for any public deploy —
# it protects your API credits and the Prompt Agent's shell tools). Leave both
# blank to run the demo open (fine for local dev).
BASIC_AUTH_USER=
BASIC_AUTH_PASS=
